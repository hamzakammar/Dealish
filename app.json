{
  "expo": {
    "name": "Dealish",
    "slug": "Dealish",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dealish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FE902A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Dealish",
      "infoPlist": {
        "NSAllowsLocalNetworking": true,
        "NSBonjourServices": [
          "_http._tcp",
          "_http._tcp"
        ]
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FE902A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Dealish",
      "useNextNotificationsApi": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dealish to access your camera to scan QR codes for tracking visits."
        }
      ],
      "./plugins/withEntitlementsModification",
      "./plugins/withGoogleMaps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c8d4d9ee-1ec9-4e2c-a60f-fa51168853fe"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c8d4d9ee-1ec9-4e2c-a60f-fa51168853fe"
    }
  }
}
