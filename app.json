{
  "expo": {
    "name": "Dealish",
    "slug": "Dealish",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "dealish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FE902A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ca.hamzaammar.dealish",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Dealish uses your location to show nearby restaurant deals.",
        "NSLocationAlwaysUsageDescription": "Dealish uses your location to show nearby restaurant deals.",
        "NSCameraUsageDescription": "Dealish uses your camera to scan deal QR codes."
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "icon": "./assets/images/app-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#FE902A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ca.hamzaammar.dealish",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hpsoqjpzebkkxdqapegl.supabase.co",
              "pathPrefix": "/auth/v1/verify"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "dealish"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dealish to access your camera to scan QR codes for tracking visits."
        }
      ],
      "./plugins/withEntitlementsModification",
      "./plugins/withGoogleMaps",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c8d4d9ee-1ec9-4e2c-a60f-fa51168853fe"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c8d4d9ee-1ec9-4e2c-a60f-fa51168853fe"
    }
  }
}
