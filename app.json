{
  "expo": {
    "name": "Dealish",
    "slug": "Dealish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dealish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FE902A"
    },
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Dealish",
      "infoPlist": {
        "NSAllowsLocalNetworking": true,
        "NSBonjourServices": ["_http._tcp"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FE902A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Dealish",
      "useNextNotificationsApi": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dealish to access your camera to scan QR codes for tracking visits."
        }
      ],
      "./plugins/withEntitlementsModification"
      // Temporarily disabled - requires paid Apple Developer account for Push Notifications
      // [
      //   "expo-notifications",
      //   {
      //     "icon": "./assets/images/icon.png",
      //     "color": "#FE902A",
      //     "sounds": []
      //   }
      // ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
